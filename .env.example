# Public metadata base URL used in app/layout.js
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Server-only API key for chat route (recommended)
GROQ_API_KEY=your_groq_api_key

# Optional legacy fallback key name supported by the route
MY_SECRET_API_KEY=

# Optional: model override (defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Not recommended for secrets; kept for compatibility with current code
NEXT_PUBLIC_GROQ_API_KEY=

# Contact form (EmailJS - public browser SDK keys)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
